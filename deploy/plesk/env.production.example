# AutoResolve Production Environment — refundgod.fans
# Copy this to .env on your Plesk server inside the autoresolve/ folder
# Never commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
PUBLIC_DOMAIN=refundgod.fans

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:YOURPASS@ep-wandering-flower-ann7uher.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-64-random-chars
DASHBOARD_PASSWORD_HASH=your-bcrypt-hash-here
ENCRYPTION_KEY=your-32-char-aes-key-here

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── AutoResolve / Dolphin Anty ────────────────────────────────────────────────
RELAY_URL=http://64.188.112.247:4001
RELAY_SECRET=your-relay-secret-here
DOLPHIN_API_TOKEN=your-dolphin-api-token-here
DOLPHIN_EMAIL=your-dolphin-email
DOLPHIN_PASSWORD=your-dolphin-password

# ── Proxy (SpyderProxy) ───────────────────────────────────────────────────────
PROXY_USER=your-proxy-user
PROXY_PASS=your-proxy-pass

# ── API security ──────────────────────────────────────────────────────────────
FORMS_API_KEY=your-api-key-here
